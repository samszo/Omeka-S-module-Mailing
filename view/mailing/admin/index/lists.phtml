<?php
$this->htmlElement('body')->appendAttribute('class', 'mailing lists');
$this->headTitle($this->translate('Mailing - Lists'));
?>

<nav class="breadcrumbs">
    <?php echo $this->hyperlink($this->translate('Mailing'), $this->url('admin/mailing')); ?>
    <span class="separator">/</span>
    <span><?php echo $this->translate('Lists'); ?></span>
</nav>

<div id="page-actions">
    <?php echo $this->hyperlink($this->translate('Back to Mailing'), $this->url('admin/mailing'), ['class' => 'button']); ?>
</div>

<h1><?php echo $this->translate('Mailing Lists'); ?></h1>

<div class="lists-list">
    <?php if (empty($lists)): ?>
        <p><?php echo $this->translate('No mailing lists found.'); ?></p>
    <?php else: ?>
        <table class="tablesaw" data-tablesaw-mode="stack">
            <thead>
                <tr>
                    <th><?php echo $this->translate('ID'); ?></th>
                    <th><?php echo $this->translate('Name'); ?></th>
                    <th><?php echo $this->translate('Type'); ?></th>
                    <th><?php echo $this->translate('Subscribers'); ?></th>
                    <th><?php echo $this->translate('Status'); ?></th>
                    <th><?php echo $this->translate('Created At'); ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($lists as $list): ?>
                    <tr>
                        <td><?php echo $this->escapeHtml($list['id']); ?></td>
                        <td><?php echo $this->escapeHtml($list['name']); ?></td>
                        <td><?php echo $this->escapeHtml($list['type']); ?></td>
                        <td><?php echo $this->escapeHtml($list['subscriber_count']); ?></td>
                        <td>
                            <span class="status-badge status-<?php echo $this->escapeHtmlAttr($list['status']); ?>">
                                <?php echo $this->escapeHtml($list['status']); ?>
                            </span>
                        </td>
                        <td><?php echo $this->escapeHtml($list['created_at']); ?></td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    <?php endif; ?>
</div>
